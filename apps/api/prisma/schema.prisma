// ╔══════════════════════════════════════════════════════════════╗
// ║  Community Hero — Prisma Schema                             ║
// ║  Database: PostgreSQL                                       ║
// ╚══════════════════════════════════════════════════════════════╝

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════

enum Role {
  CITIZEN
  MODERATOR
  ADMIN
  ORCHESTRATOR
}

enum IssueCategory {
  POTHOLE
  ROAD_DAMAGE
  STREETLIGHT
  TRAFFIC_SIGNAL
  GARBAGE
  ILLEGAL_DUMPING
  SEWAGE
  WATER_SUPPLY
  PARK_MAINTENANCE
  PUBLIC_SAFETY
  NOISE_COMPLAINT
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum VoteType {
  UPVOTE
  VERIFY
  DISPUTE
}

enum NotificationType {
  ISSUE_STATUS_CHANGED
  STATUS_UPDATE
  NEW_COMMENT
  ISSUE_COMMENTED
  BADGE_EARNED
  BADGE_AWARDED
  KARMA_EARNED
  SYSTEM_ALERT
  SYSTEM_ANNOUNCEMENT
  ISSUE_ASSIGNED
  ISSUE_UPVOTED
}

enum ChallengeTargetType {
  REPORT_ISSUES
  VERIFY_ISSUES
  EARN_KARMA
  REPORT_N
  VERIFY_N
}

enum KarmaActionType {
  REPORT_ISSUE
  VERIFY_ISSUE
  ISSUE_VERIFIED
  RESOLVED_ISSUE
  DAILY_LOGIN
  PIONEER_BONUS
}







// ═══════════════════════════════════════════════
//  NEXTAUTH.JS MODELS
// ═══════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════
//  DOMAIN MODELS
// ═══════════════════════════════════════════════

/// Platform user — citizens, moderators, and admins.
model User {
  id            String    @id @default(cuid())
  name          String?
  phone         String?   @unique
  email         String?   @unique
  password      String?
  avatarUrl     String?
  role          Role      @default(CITIZEN)
  karma         Int       @default(0)
  city          String?   
  ward          String?   
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Relations ──
  accounts               Account[]
  sessions               Session[]
  reportedIssues         Issue[]                  @relation("ReportedIssues")
  assignedIssues         Issue[]                  @relation("AssignedIssues")
  comments               Comment[]
  votes                  Vote[]
  badges                 UserBadge[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreferences NotificationPreference[]
  karmaHistory           KarmaHistory[]
  userChallenges         UserChallenge[]
  auditLogs              AuditLog[]

  @@map("users")
}

/// A civic issue reported by a citizen.
/// Supports soft-delete via the `deletedAt` field.
model Issue {
  id          String        @id @default(cuid())
  title       String        
  description String        
  category    IssueCategory
  status      IssueStatus   @default(OPEN)
  severity    IssueSeverity @default(MEDIUM)

  // ── Location ──
  latitude  Float
  longitude Float
  address   String? 
  ward      String? 

  // ── Denormalized counter for fast reads ──
  upvoteCount Int @default(0)

  // ── Timestamps ──
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  deletedAt  DateTime? // soft-delete

  // ── Relations ──
  reportedById String
  reportedBy   User   @relation("ReportedIssues", fields: [reportedById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedIssues", fields: [assignedToId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  media    IssueMedia[]
  comments Comment[]
  votes    Vote[]

  // ── Indexes ──
  @@index([latitude, longitude], map: "idx_issue_geo")
  @@index([status], map: "idx_issue_status")
  @@index([ward], map: "idx_issue_ward")
  @@index([category], map: "idx_issue_category")
  @@index([reportedById], map: "idx_issue_reporter")
  @@index([assignedToId], map: "idx_issue_assignee")
  @@index([departmentId], map: "idx_issue_department")
  @@index([createdAt], map: "idx_issue_created")
  @@index([deletedAt], map: "idx_issue_soft_delete")
  @@map("issues")
}

/// Media files (images/videos) attached to an issue.
model IssueMedia {
  id       String    @id @default(cuid())
  issueId  String
  url      String
  type     MediaType
  aiLabels String @default("[]") // AI-generated labels for the media

  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId], map: "idx_media_issue")
  @@map("issue_media")
}

/// User comment on an issue.
model Comment {
  id       String  @id @default(cuid())
  issueId  String
  userId   String
  parentId String?
  text     String  
  isSystem Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  issue    Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([issueId], map: "idx_comment_issue")
  @@index([userId], map: "idx_comment_user")
  @@index([parentId], map: "idx_comment_parent")
  @@map("comments")
}

/// Dynamic configuration parameters for a specific ward.
model WardConfig {
  wardName              String   @id 
  verificationThreshold Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("ward_configs")
}

/// Vote on an issue — upvote, verify, or dispute.
/// Each user can cast one vote of each type per issue.
model Vote {
  id      String   @id @default(cuid())
  issueId String
  userId  String
  type    VoteType

  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issueId, userId, type], map: "uq_vote_per_user_type")
  @@index([issueId], map: "idx_vote_issue")
  @@map("votes")
}

/// Achievable badge definition.
model Badge {
  id          String @id @default(cuid())
  internalKey String @unique  // e.g., FIRST_RESPONDER
  name        String @unique 
  description String 
  iconUrl     String
  condition   String  // JSON or human-readable rule description

  createdAt DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

/// Junction table: user ↔ badge.
model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId], map: "idx_userbadge_user")
  @@map("user_badges")
}

/// Karma point allocation rules.
model KarmaConfig {
  actionType KarmaActionType @id
  points     Int
  updatedAt  DateTime        @updatedAt

  @@map("karma_configs")
}

/// History of karma points awarded to a user.
model KarmaHistory {
  id         String          @id @default(cuid())
  userId     String
  actionType KarmaActionType
  points Int
  referenceId String?        // e.g. issueId, commentId

  createdAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_karma_history_user")
  @@index([createdAt], map: "idx_karma_history_date")
  @@map("karma_history")
}

/// In-app notification delivered to a user.
model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  payload Json // Flexible JSON payload (issueId, message, etc.)
  read    Boolean          @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read], map: "idx_notification_user_unread")
  @@index([createdAt], map: "idx_notification_created")
  @@map("notifications")
}

/// User's notification channel preferences for different event types.
model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  inApp   Boolean          @default(true)
  email   Boolean          @default(true)
  push    Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], map: "uq_preference_user_type")
  @@map("notification_preferences")
}

/// Web Push API subscription endpoint and keys for a user.
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String 
  p256dh   String 
  auth     String 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([endpoint], map: "uq_push_endpoint")
  @@index([userId], map: "idx_push_user")
  @@map("push_subscriptions")
}

/// Government department responsible for resolving issues.
model Department {
  id              String          @id @default(cuid())
  name            String          @unique 
  contactEmail    String          
  issueCategories String @default("[]") // Categories this department handles

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues Issue[]

  @@map("departments")
}

/// Monthly or weekly civic challenges configured by admins.
model Challenge {
  id            String              @id @default(cuid())
  title         String              
  description   String              
  targetAction ChallengeTargetType
  targetCount Int
  rewardKarma   Int
  rewardBadgeId String?             // Optional badge reward
  
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())

  users         UserChallenge[]

  @@index([isActive, startDate, endDate], map: "idx_challenge_active")
  @@map("challenges")
}

/// Tracks a user's progress against a specific challenge.
model UserChallenge {
  userId      String
  challengeId String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
  @@index([userId, completed], map: "idx_userchallenge_status")
  @@map("user_challenges")
}

/// Audit log for administrative and critical actions.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   
  payload   String?
  ipAddress String?  
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_audit_user")
  @@index([createdAt], map: "idx_audit_created")
  @@map("audit_logs")
}
