  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.3",
    "@types/json2csv": "^5.0.7",
    "@types/node": "^20.14.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^8.57.0",
